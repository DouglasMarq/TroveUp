{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TroveUp",
  "version": "1.0.1",
  "identifier": "com.troveup.app",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "TroveUp",
        "width": 1100,
        "height": 750,
        "minWidth": 800,
        "minHeight": 550
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["trove"]
      }
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/DouglasMarq/TroveUp/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDNBMkNCNEFGMTNGQTIyQgpSV1Fyb2oveFNzdWlBeUlvSHc5OHRZeStETnRBazEyTk9UWTY5T1VQS2JPV1l6bVRVUEFGb2p5Tgo=",
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
